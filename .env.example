# Get this from your Arkesel dashboard: Settings > API Keys
ARKESEL_API_KEY=

# Your registered Arkesel Sender ID (max 11 characters, must be pre-approved
# in your Arkesel dashboard before it will actually send)
SMS_SENDER_ID=PharmCncl

# Optional: your app's public URL + /api/webhooks/arkesel
# Only needed if you want Arkesel to call this per-send (alternative to
# registering one fixed callback URL in the dashboard, see README).
# ARKESEL_CALLBACK_URL=https://your-app-domain.com/api/webhooks/arkesel

PORT=3000
